# NextAuth 认证配置
# 生成方式：openssl rand -base64 32
AUTH_SECRET=test-secret-key-for-development-only

POSTGRES_HOST=localhost  # docker-compose 启动时使用服务名 postgres，开发环境可以改为 localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# SQLAdmin 后台超级管理员账号密码
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456