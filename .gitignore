# ==========================================
# Python 核心运行时缓存
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
# ==========================================
# 虚拟环境 (极其重要，严禁提交)
# ==========================================
.venv/
venv/
env/
ENV/

# ==========================================
# 环境变量与敏感配置 (安全红线)
# ==========================================
.env
.env.*
!.env.example
*.pem
*.key
credentials.json

# ==========================================
# 本地数据与日志 (防止大文件撑爆 Git)
# ==========================================
*.log
*.sqlite3
*.db
/data/
/logs/
/temp/
/tmp/

# ==========================================
# 测试与代码质量工具缓存
# ==========================================
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/

# ==========================================
# 打包与发布产物
# ==========================================
build/
dist/
downloads/
eggs/
.eggs/
*.egg-info/
*.egg
wheels/

# ==========================================
# IDE、编辑器与系统级配置
# ==========================================
.vscode/
.idea/
.cursor/
*.swp
*.swo

# 操作系统生成的垃圾文件
.DS_Store
.DS_Store?
._*
Thumbs.db